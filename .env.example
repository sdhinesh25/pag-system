# Supabase project credentials (Project Settings → API).
# Copy to .env and fill in. Both are safe to expose in the browser
# (the anon key is public; protect data with Row Level Security).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Anthropic API key for the AI Risk Analysis feature (Account Detail page).
# No VITE_ prefix → server-side only. Used by the /api/analyze serverless function,
# never bundled into the browser. Set the same variable in the Vercel dashboard for prod.
ANTHROPIC_KEY=sk-ant-...
