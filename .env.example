# Supabase project credentials (Project Settings → API).
# Copy to .env and fill in. Both are safe to expose in the browser
# (the anon key is public; protect data with Row Level Security).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Anthropic API key for the AI Risk Analysis feature (Account Detail page).
# ⚠ This is bundled into the browser build — for LOCAL/DEMO use only.
# Do NOT deploy publicly with a real key, or it will be exposed to anyone.
VITE_ANTHROPIC_KEY=sk-ant-...
